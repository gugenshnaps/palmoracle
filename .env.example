OPENROUTER_API_KEY=

# Бесплатная инфографика (фото ладони → картинка-гид)
# Рекомендуется: openai/gpt-5-image
OPENROUTER_INFOGRAPHIC_MODEL=openai/gpt-5-image
OPENROUTER_INFOGRAPHIC_MODEL_FALLBACK=google/gemini-2.5-flash-image

# Платный текстовый разбор (позже)
OPENROUTER_PAID_TEXT_MODEL=openai/gpt-4o

OPENROUTER_SITE_URL=https://your-domain.vercel.app

# Telegram (только сервер — BotFather → /token)
TELEGRAM_BOT_TOKEN=

NEXT_PUBLIC_BOT_USERNAME=
NEXT_PUBLIC_ENABLE_PAYWALL=false
